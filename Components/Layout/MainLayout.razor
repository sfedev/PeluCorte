@inherits LayoutComponentBase

<nav class="navbar navbar-expand-lg pc-navbar">
    <div class="container">
        <a class="navbar-brand" href="/">
            <i class="bi bi-scissors"></i>PeluCorte
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#pcNavbar" aria-controls="pcNavbar"
                aria-expanded="false" aria-label="Abrir menú">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="pcNavbar">
            <div class="navbar-nav ms-lg-auto align-items-lg-center gap-lg-2">
                <button type="button" class="pc-nav-link" id="pc-toggle-tema"
                        onclick="window.PeluCorteUI.toggleTema(); window.PeluCorteUI.refrescarIconoTema();"
                        title="Cambiar tema">
                    <i class="bi bi-moon me-1 d-lg-none" id="pc-tema-icono"></i>
                    <i class="bi bi-moon d-none d-lg-inline" aria-hidden="true"></i>
                    <span class="d-lg-none">Cambiar tema</span>
                </button>

                <AuthorizeView>
                    <Authorized>
                        <AuthorizeView Roles="@Roles.SuperAdmin" Context="superCtx">
                            <a href="/super-admin" class="pc-nav-link" id="pc-super-admin-link">
                                <i class="bi bi-shield-check me-1"></i>Super admin
                                <span id="pc-pending-badge" class="pc-pending-badge" style="display:none;">0</span>
                            </a>
                            <script>
                                (function(){
                                    if (window.pcPendingFetched) return;
                                    window.pcPendingFetched = true;
                                    fetch('/api/pendientes-count', { credentials: 'same-origin' })
                                        .then(r => r.ok ? r.json() : null)
                                        .then(d => {
                                            if (!d || !d.count) return;
                                            var b = document.getElementById('pc-pending-badge');
                                            if (b) { b.textContent = d.count; b.style.display = 'inline-block'; }
                                        })
                                        .catch(() => {});
                                })();
                            </script>
                        </AuthorizeView>
                        <AuthorizeView Roles="@Roles.Dueno" Context="duenoCtx">
                            <a href="/admin" class="pc-nav-link"><i class="bi bi-gear me-1"></i>Mi peluquería</a>
                        </AuthorizeView>
                        <AuthorizeView Roles="@Roles.Empleado" Context="empleadoCtx">
                            <a href="/mi-agenda" class="pc-nav-link"><i class="bi bi-calendar-week me-1"></i>Mi agenda</a>
                        </AuthorizeView>
                        <span class="pc-nav-user d-none d-lg-inline">
                            <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                        </span>
                        <form method="post" action="/api/logout" style="margin:0;">
                            <button type="submit" class="pc-nav-link pc-nav-btn">
                                <i class="bi bi-box-arrow-right me-1"></i>Salir
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/" class="pc-nav-link"><i class="bi bi-search me-1"></i>Buscar</a>
                        <a href="/mis-citas" class="pc-nav-link"><i class="bi bi-calendar-check me-1"></i>Mis citas</a>
                        <a href="/registro" class="pc-nav-link"><i class="bi bi-shop me-1"></i>Soy peluquería</a>
                        <a href="/login" class="pc-nav-link pc-nav-link-cta"><i class="bi bi-box-arrow-in-right me-1"></i>Entrar</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

<main class="container py-4">
    @Body
</main>

<footer class="pc-footer">
    <div class="container d-flex justify-content-between flex-wrap gap-2 small text-muted">
        <span>&copy; @DateTime.Now.Year PeluCorte</span>
        <div class="d-flex gap-3">
            <a href="/privacidad">Privacidad</a>
            <a href="/registro">Soy peluquería</a>
        </div>
    </div>
</footer>

<div class="pc-cookie-banner" id="pc-cookie-banner" style="display:none;">
    <div class="container d-flex flex-wrap align-items-center gap-2">
        <i class="bi bi-cookie d-none d-sm-inline" style="font-size: 1.4rem; color: var(--pc-primary);"></i>
        <span class="flex-grow-1 small">
            Usamos cookies técnicas necesarias para que la app funcione. <a href="/privacidad">Más info</a>.
        </span>
        <button class="btn btn-sm pc-btn-primary" onclick="window.PeluCorteUI.aceptarCookies(); document.getElementById('pc-cookie-banner').style.display='none';">Aceptar</button>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ha ocurrido un error inesperado.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>
