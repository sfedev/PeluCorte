@page "/admin/servicios"
@attribute [Authorize(Policy = "EsDueno")]
@rendermode InteractiveServer
@inject ServicioService ServicioService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState

<PageTitle>PeluCorte · Servicios</PageTitle>

@if (mensaje is not null)
{
    <div class="pc-toast @(mensajeOk ? "success" : "error")">
        <i class="bi @(mensajeOk ? "bi-check-circle" : "bi-exclamation-circle") me-1"></i>@mensaje
    </div>
}

<div class="pc-admin-header d-flex flex-wrap align-items-center gap-3 mb-3">
    <div>
        <h2 class="mb-1"><i class="bi bi-tag me-2" style="color: var(--pc-primary);"></i>Servicios</h2>
        <p class="text-muted mb-0 small"><a href="/admin"><i class="bi bi-arrow-left me-1"></i>Volver al panel</a></p>
    </div>
</div>

<div class="card pc-card mb-4">
    <div class="card-header pc-card-header"><h5><i class="bi bi-plus-circle me-2" style="color: var(--pc-primary);"></i>Nuevo servicio</h5></div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-5">
                <label class="pc-form-label">Nombre</label>
                <input class="form-control pc-form-control" @bind="nuevoNombre" placeholder="Corte, Tinte, Mechas..." />
            </div>
            <div class="col-md-3">
                <label class="pc-form-label">Duración (min)</label>
                <input type="number" min="15" step="15" class="form-control pc-form-control" @bind="nuevaDuracion" />
            </div>
            <div class="col-md-2">
                <label class="pc-form-label">Precio (€)</label>
                <input type="number" step="0.5" class="form-control pc-form-control" @bind="nuevoPrecio" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn pc-btn-primary w-100" @onclick="Crear" disabled="@(string.IsNullOrWhiteSpace(nuevoNombre))">
                    <i class="bi bi-plus-lg me-1"></i>Añadir
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card pc-card">
    <div class="card-body p-3">
        @if (servicios.Count == 0)
        {
            <div class="pc-empty"><i class="bi bi-tag"></i><p class="mb-0">Aún no has creado servicios. Si no creas ninguno, las citas se reservarán con duración por defecto de 30 minutos.</p></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr><th>Nombre</th><th>Duración</th><th>Precio</th><th>Estado</th><th class="text-end"></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in servicios)
                        {
                            <tr>
                                <td>
                                    @if (editandoId == s.Id) { <input class="form-control pc-form-control form-control-sm" @bind="edNombre" /> }
                                    else { <strong>@s.Nombre</strong> }
                                </td>
                                <td style="width: 130px;">
                                    @if (editandoId == s.Id) { <input type="number" class="form-control pc-form-control form-control-sm" @bind="edDuracion" min="15" step="15" /> }
                                    else { @s.DuracionMinutos<text> min</text> }
                                </td>
                                <td style="width: 100px;">
                                    @if (editandoId == s.Id) { <input type="number" class="form-control pc-form-control form-control-sm" @bind="edPrecio" step="0.5" /> }
                                    else if (s.Precio.HasValue) { @s.Precio.Value.ToString("F2")<text> €</text> }
                                    else { <span class="text-muted small">—</span> }
                                </td>
                                <td>
                                    @if (editandoId == s.Id)
                                    {
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" @bind="edActivo" id="@($"act-{s.Id}")" />
                                            <label class="form-check-label small" for="@($"act-{s.Id}")">Activo</label>
                                        </div>
                                    }
                                    else if (s.Activo)
                                    { <span class="pc-estado pc-estado-aprobada">Activo</span> }
                                    else
                                    { <span class="pc-estado pc-estado-rechazada">Inactivo</span> }
                                </td>
                                <td class="text-end">
                                    @if (editandoId == s.Id)
                                    {
                                        <button class="btn btn-sm btn-success me-1" @onclick="() => GuardarEdicion(s)"><i class="bi bi-check"></i></button>
                                        <button class="btn btn-sm btn-light" @onclick="() => editandoId = null"><i class="bi bi-x"></i></button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-light me-1" @onclick="() => Editar(s)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(s.Id)"><i class="bi bi-trash"></i></button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private Guid? peluqueriaId;
    private List<Servicio> servicios = new();
    private string nuevoNombre = string.Empty;
    private int nuevaDuracion = 30;
    private decimal? nuevoPrecio;

    private Guid? editandoId;
    private string edNombre = string.Empty;
    private int edDuracion = 30;
    private decimal? edPrecio;
    private bool edActivo = true;

    private string? mensaje;
    private bool mensajeOk;
    private CancellationTokenSource? mensajeCts;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userId = UserManager.GetUserId(auth.User);
        if (userId is null) return;
        var user = await UserManager.FindByIdAsync(userId);
        peluqueriaId = user?.PeluqueriaId;
        if (peluqueriaId is null) return;
        await Recargar();
    }

    private async Task Recargar()
    {
        if (peluqueriaId is null) return;
        servicios = await ServicioService.ObtenerPorPeluqueriaAsync(peluqueriaId.Value);
    }

    private async Task Crear()
    {
        if (peluqueriaId is null || string.IsNullOrWhiteSpace(nuevoNombre)) return;
        await ServicioService.CrearAsync(peluqueriaId.Value, nuevoNombre, nuevaDuracion, nuevoPrecio);
        nuevoNombre = string.Empty; nuevaDuracion = 30; nuevoPrecio = null;
        await Recargar();
        await Mostrar("Servicio creado.", true);
    }

    private void Editar(Servicio s)
    {
        editandoId = s.Id;
        edNombre = s.Nombre;
        edDuracion = s.DuracionMinutos;
        edPrecio = s.Precio;
        edActivo = s.Activo;
    }

    private async Task GuardarEdicion(Servicio s)
    {
        await ServicioService.ActualizarAsync(s.Id, edNombre, edDuracion, edPrecio, edActivo);
        editandoId = null;
        await Recargar();
        await Mostrar("Servicio actualizado.", true);
    }

    private async Task Eliminar(Guid id)
    {
        if (peluqueriaId is null) return;
        await ServicioService.EliminarAsync(id, peluqueriaId);
        await Recargar();
        await Mostrar("Servicio eliminado.", true);
    }

    private async Task Mostrar(string texto, bool ok)
    {
        mensajeCts?.Cancel();
        mensajeCts = new CancellationTokenSource();
        var token = mensajeCts.Token;
        mensaje = texto; mensajeOk = ok; StateHasChanged();
        try { await Task.Delay(3500, token); mensaje = null; StateHasChanged(); } catch { }
    }
}
