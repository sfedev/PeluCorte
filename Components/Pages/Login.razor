@page "/login"

<PageTitle>PeluCorte · Iniciar sesión</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card pc-card">
            <div class="card-body p-4">
                <h3 class="mb-1"><i class="bi bi-box-arrow-in-right me-2" style="color: var(--pc-primary);"></i>Iniciar sesión</h3>
                <p class="text-muted small mb-4">Accede al panel de tu peluquería.</p>

                @if (Reset == "1")
                {
                    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i>Contraseña actualizada. Ya puedes iniciar sesión.</div>
                }
                @if (Error == "credenciales")
                {
                    <div class="alert alert-danger py-2"><i class="bi bi-x-circle me-1"></i>Email o contraseña incorrectos.</div>
                }
                else if (Error == "pendiente")
                {
                    <div class="alert alert-warning py-2"><i class="bi bi-hourglass me-1"></i>Tu peluquería aún no ha sido aprobada.</div>
                }
                else if (Error == "bloqueado")
                {
                    <div class="alert alert-warning py-2"><i class="bi bi-lock me-1"></i>Cuenta temporalmente bloqueada.</div>
                }

                <form method="post" action="/api/login">
                    <input type="hidden" name="returnUrl" value="@(ReturnUrl ?? "")" />
                    <div class="mb-3">
                        <label class="pc-form-label">Email</label>
                        <input type="email" name="email" class="form-control pc-form-control" required autocomplete="email" />
                    </div>
                    <div class="mb-3">
                        <label class="pc-form-label">Contraseña</label>
                        <input type="password" name="password" class="form-control pc-form-control" required autocomplete="current-password" />
                    </div>
                    <button type="submit" class="btn pc-btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                    </button>
                </form>

                <p class="text-center small mt-3 mb-0">
                    <a href="/forgot-password">¿Olvidaste tu contraseña?</a>
                </p>

                <hr class="my-4" />
                <p class="text-center small text-muted mb-0">
                    ¿Tienes una peluquería? <a href="/registro">Solicita el alta</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Reset { get; set; }
}
