@page "/admin/estadisticas"
@attribute [Authorize(Policy = "EsDueno")]
@rendermode InteractiveServer
@inject EstadisticasService EstadisticasService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState

<PageTitle>PeluCorte · Estadísticas</PageTitle>

<div class="pc-admin-header d-flex flex-wrap align-items-center gap-3 mb-3">
    <div>
        <h2 class="mb-1"><i class="bi bi-bar-chart me-2" style="color: var(--pc-primary);"></i>Estadísticas</h2>
        <p class="text-muted mb-0 small"><a href="/admin"><i class="bi bi-arrow-left me-1"></i>Volver al panel</a></p>
    </div>
</div>

@if (cargando) { <div class="pc-empty"><div class="spinner-border text-primary"></div></div> }
else if (resumen is null) { <div class="pc-empty"><i class="bi bi-x-circle"></i><p class="mb-0">No se han podido cargar los datos.</p></div> }
else
{
    <div class="pc-stats">
        <div class="pc-stat">
            <div class="pc-stat-icon purple"><i class="bi bi-calendar-event"></i></div>
            <div><span class="pc-stat-label">Hoy</span><span class="pc-stat-value">@resumen.CitasHoy</span></div>
        </div>
        <div class="pc-stat">
            <div class="pc-stat-icon pink"><i class="bi bi-calendar-week"></i></div>
            <div><span class="pc-stat-label">Esta semana</span><span class="pc-stat-value">@resumen.CitasSemana</span></div>
        </div>
        <div class="pc-stat">
            <div class="pc-stat-icon green"><i class="bi bi-calendar-month"></i></div>
            <div><span class="pc-stat-label">Este mes</span><span class="pc-stat-value">@resumen.CitasMes</span></div>
        </div>
        <div class="pc-stat">
            <div class="pc-stat-icon purple"><i class="bi bi-calendar-plus"></i></div>
            <div><span class="pc-stat-label">Futuras</span><span class="pc-stat-value">@resumen.CitasFuturas</span></div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card pc-card h-100">
                <div class="card-header pc-card-header"><h5><i class="bi bi-trophy me-2" style="color: var(--pc-primary);"></i>Peluquero más solicitado (este mes)</h5></div>
                <div class="card-body p-4 text-center">
                    @if (!string.IsNullOrEmpty(resumen.TopPeluqueroNombre))
                    {
                        <div style="font-size: 1.6rem; font-weight: 700; color: var(--pc-primary);">@resumen.TopPeluqueroNombre</div>
                        <div class="text-muted">@resumen.TopPeluqueroCount citas</div>
                    }
                    else { <div class="text-muted">Aún no hay datos suficientes.</div> }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card pc-card h-100">
                <div class="card-header pc-card-header"><h5><i class="bi bi-clock me-2" style="color: var(--pc-primary);"></i>Hora más popular</h5></div>
                <div class="card-body p-4 text-center">
                    @if (resumen.HoraMasPopular.HasValue)
                    {
                        <div style="font-size: 1.6rem; font-weight: 700; color: var(--pc-primary);">@resumen.HoraMasPopular.Value.ToString("HH\\:mm")</div>
                    }
                    else { <div class="text-muted">Sin datos.</div> }
                </div>
            </div>
        </div>
    </div>

    <div class="card pc-card mt-4">
        <div class="card-header pc-card-header"><h5><i class="bi bi-graph-up me-2" style="color: var(--pc-primary);"></i>Citas por día (últimos 30 días)</h5></div>
        <div class="card-body p-3">
            @if (porDia.Count == 0) { <div class="text-muted text-center py-3">Sin actividad reciente.</div> }
            else
            {
                <div class="pc-chart">
                    @{
                        var max = porDia.Max(d => d.Total);
                    }
                    @foreach (var d in porDia)
                    {
                        var altura = max == 0 ? 0 : (int)((d.Total / (double)max) * 100);
                        <div class="pc-chart-bar" title="@d.Fecha.ToString("dd/MM"): @d.Total citas">
                            <div class="pc-chart-fill" style="height: @(altura)%;"></div>
                            <div class="pc-chart-label">@d.Fecha.Day</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private Guid? peluqueriaId;
    private EstadisticasService.Resumen? resumen;
    private List<EstadisticasService.DiaConteo> porDia = new();
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userId = UserManager.GetUserId(auth.User);
        if (userId is null) { cargando = false; return; }
        var user = await UserManager.FindByIdAsync(userId);
        peluqueriaId = user?.PeluqueriaId;
        if (peluqueriaId is null) { cargando = false; return; }

        resumen = await EstadisticasService.ObtenerResumenAsync(peluqueriaId.Value);
        porDia = await EstadisticasService.ObtenerCitasPorDiaAsync(peluqueriaId.Value, 30);
        cargando = false;
    }
}
