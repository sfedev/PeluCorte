@page "/reset-password"

<PageTitle>PeluCorte · Nueva contraseña</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card pc-card">
            <div class="card-body p-4">
                <h3 class="mb-1"><i class="bi bi-shield-lock me-2" style="color: var(--pc-primary);"></i>Nueva contraseña</h3>
                <p class="text-muted small mb-4">Introduce una nueva contraseña para tu cuenta.</p>

                @if (string.IsNullOrEmpty(Token) || string.IsNullOrEmpty(Email))
                {
                    <div class="alert alert-danger py-2">
                        <i class="bi bi-x-circle me-1"></i>Enlace no válido o caducado. <a href="/forgot-password">Solicita uno nuevo</a>.
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(Error))
                    {
                        <div class="alert alert-danger py-2">
                            <i class="bi bi-x-circle me-1"></i>@Error
                        </div>
                    }

                    <form method="post" action="/api/reset-password">
                        <input type="hidden" name="email" value="@Email" />
                        <input type="hidden" name="token" value="@Token" />
                        <div class="mb-3">
                            <label class="pc-form-label">Cuenta</label>
                            <input type="email" class="form-control pc-form-control" value="@Email" disabled />
                        </div>
                        <div class="mb-3">
                            <label class="pc-form-label">Nueva contraseña</label>
                            <input type="password" name="password" class="form-control pc-form-control" required minlength="8" autocomplete="new-password" />
                            <small class="text-muted">Mínimo 8 caracteres, con mayúscula, minúscula y número.</small>
                        </div>
                        <button type="submit" class="btn pc-btn-primary w-100">
                            <i class="bi bi-check2-circle me-1"></i>Cambiar contraseña
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
