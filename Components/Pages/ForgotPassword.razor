@page "/forgot-password"

<PageTitle>PeluCorte · Recuperar contraseña</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card pc-card">
            <div class="card-body p-4">
                <h3 class="mb-1"><i class="bi bi-key me-2" style="color: var(--pc-primary);"></i>Recuperar contraseña</h3>
                <p class="text-muted small mb-4">Te enviaremos un enlace por email para restablecerla.</p>

                @if (Enviado == "1")
                {
                    <div class="alert alert-success py-2">
                        <i class="bi bi-check-circle me-1"></i>Si el email existe, recibirás un enlace en breve.
                    </div>
                }

                <form method="post" action="/api/forgot-password">
                    <div class="mb-3">
                        <label class="pc-form-label">Email</label>
                        <input type="email" name="email" class="form-control pc-form-control" required autocomplete="email" />
                    </div>
                    <button type="submit" class="btn pc-btn-primary w-100">
                        <i class="bi bi-send me-1"></i>Enviar enlace
                    </button>
                </form>

                <hr class="my-4" />
                <p class="text-center small text-muted mb-0">
                    <a href="/login"><i class="bi bi-arrow-left me-1"></i>Volver al login</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Enviado { get; set; }
}
