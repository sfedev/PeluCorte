@page "/Error"
@using System.Diagnostics

<PageTitle>PeluCorte · Error</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-7 text-center">
        <div class="pc-not-found">
            <div class="pc-not-found-num" style="font-size: 5rem;"><i class="bi bi-exclamation-octagon"></i></div>
            <h2 class="mb-3">Algo no ha ido bien</h2>
            <p class="text-muted">Ha ocurrido un error inesperado al procesar tu solicitud. Ya estamos al tanto. Por favor, inténtalo de nuevo en unos minutos.</p>

            @if (ShowRequestId)
            {
                <p class="text-muted small mt-4">
                    <strong>ID de la incidencia:</strong> <code>@RequestId</code>
                </p>
            }

            <div class="d-flex gap-2 justify-content-center mt-3">
                <a href="/" class="btn pc-btn-primary"><i class="bi bi-house me-1"></i>Volver al inicio</a>
                <button class="btn btn-light" onclick="history.back()"><i class="bi bi-arrow-left me-1"></i>Atrás</button>
            </div>
        </div>
    </div>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
