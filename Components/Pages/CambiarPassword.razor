@page "/cambiar-password"
@attribute [Authorize]

<PageTitle>PeluCorte · Cambiar contraseña</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card pc-card">
            <div class="card-body p-4">
                <h3 class="mb-1"><i class="bi bi-shield-lock me-2" style="color: var(--pc-primary);"></i>Cambiar contraseña</h3>
                <p class="text-muted small mb-4">Tu cuenta seguirá activa con la nueva contraseña.</p>

                @if (Ok == "1")
                {
                    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i>Contraseña actualizada.</div>
                }
                @if (!string.IsNullOrEmpty(Error))
                {
                    <div class="alert alert-danger py-2"><i class="bi bi-x-circle me-1"></i>@Error</div>
                }

                <form method="post" action="/api/cambiar-password">
                    <div class="mb-3">
                        <label class="pc-form-label">Contraseña actual</label>
                        <input type="password" name="actual" class="form-control pc-form-control" required autocomplete="current-password" />
                    </div>
                    <div class="mb-3">
                        <label class="pc-form-label">Nueva contraseña</label>
                        <input type="password" name="nueva" class="form-control pc-form-control" required minlength="8" autocomplete="new-password" />
                        <small class="text-muted">Mínimo 8 caracteres, con mayúscula, minúscula y número.</small>
                    </div>
                    <button type="submit" class="btn pc-btn-primary w-100">
                        <i class="bi bi-check2-circle me-1"></i>Cambiar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Ok { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
