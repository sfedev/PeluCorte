@page "/admin/perfil"
@attribute [Authorize(Policy = "EsDueno")]
@rendermode InteractiveServer
@inject PeluqueriaService PeluqueriaService
@inject GeoService GeoService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

@code {
    [SupplyParameterFromQuery(Name = "error")] public string? ErrorBorrado { get; set; }
}

<PageTitle>PeluCorte · Editar perfil</PageTitle>

@if (mensaje is not null)
{
    <div class="pc-toast @(mensajeOk ? "success" : "error")">
        <i class="bi @(mensajeOk ? "bi-check-circle" : "bi-exclamation-circle") me-1"></i>@mensaje
    </div>
}

@if (cargando)
{
    <div class="pc-empty"><div class="spinner-border text-primary"></div></div>
}
else if (peluqueria is null)
{
    <div class="pc-empty">
        <i class="bi bi-shop"></i>
        <p class="mb-0">No se ha podido cargar tu peluquería.</p>
    </div>
}
else
{
    <div class="pc-admin-header d-flex flex-wrap align-items-center gap-3 mb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-pencil-square me-2" style="color: var(--pc-primary);"></i>Editar perfil</h2>
            <p class="text-muted mb-0 small"><a href="/admin"><i class="bi bi-arrow-left me-1"></i>Volver al panel</a></p>
        </div>
    </div>

    <div class="card pc-card">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-7">
                    <label class="pc-form-label">Nombre de la peluquería</label>
                    <input class="form-control pc-form-control" @bind="form.Nombre" />
                </div>
                <div class="col-md-5">
                    <label class="pc-form-label">Teléfono</label>
                    <input class="form-control pc-form-control" @bind="form.Telefono"
                           inputmode="tel" autocomplete="tel" />
                </div>

                <div class="col-12">
                    <label class="pc-form-label">Dirección completa</label>
                    <input class="form-control pc-form-control" @bind="form.Direccion" placeholder="Calle, número, ciudad" />
                    <small class="text-muted">
                        <i class="bi bi-geo-alt me-1"></i>Si cambias la dirección, recalculamos la ubicación automáticamente.
                    </small>
                </div>

                <div class="col-12">
                    <label class="pc-form-label">URL de Google Maps <span class="text-muted">(opcional)</span></label>
                    <input class="form-control pc-form-control" @bind="form.GoogleMapsUrl" placeholder="https://maps.google.com/..." />
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>Para el botón "Ver en mapa" de tu página pública.
                    </small>
                </div>

                <div class="col-12">
                    <label class="pc-form-label">Horario semanal</label>
                    <div class="pc-horario-tabla">
                        @foreach (var item in form.Horarios)
                        {
                            <div class="pc-horario-fila">
                                <label class="pc-horario-check">
                                    <input type="checkbox" checked="@item.Abierto"
                                           @onchange="@(e => item.Abierto = (bool)(e.Value ?? false))" />
                                    <span>@NombreDia(item.Dia)</span>
                                </label>
                                <input class="form-control form-control-sm pc-form-control" type="text"
                                       @bind="item.Apertura" placeholder="09:00"
                                       disabled="@(!item.Abierto)" />
                                <span class="text-muted">a</span>
                                <input class="form-control form-control-sm pc-form-control" type="text"
                                       @bind="item.Cierre" placeholder="21:00"
                                       disabled="@(!item.Abierto)" />
                            </div>
                        }
                    </div>
                </div>

                <div class="col-12">
                    <label class="pc-form-label">Email de contacto público</label>
                    <input type="email" class="form-control pc-form-control" @bind="form.EmailContacto" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4 flex-wrap">
                <button class="btn pc-btn-primary" @onclick="Guardar" disabled="@guardando">
                    @if (guardando) { <span class="spinner-border spinner-border-sm me-2"></span><span>Guardando...</span> }
                    else { <i class="bi bi-check2-circle me-1"></i><span>Guardar cambios</span> }
                </button>
                <a href="/admin" class="btn btn-light">Cancelar</a>
            </div>
        </div>
    </div>

    <div class="card pc-card mt-4 border border-danger-subtle">
        <div class="card-body p-4">
            <h5 class="text-danger mb-2"><i class="bi bi-exclamation-triangle me-2"></i>Zona peligrosa</h5>
            <p class="text-muted small mb-3">Cerrar la peluquería borrará permanentemente todos los datos: peluqueros, citas, servicios, bloqueos y tu cuenta de dueño.</p>

            @if (!confirmandoBorrado)
            {
                <button class="btn btn-outline-danger" @onclick="() => confirmandoBorrado = true">
                    <i class="bi bi-trash me-1"></i>Cerrar mi peluquería
                </button>
            }
            else
            {
                <form method="post" action="/api/cerrar-peluqueria">
                    <div class="alert alert-warning small mb-3">
                        Para confirmar el cierre necesitamos dos cosas:
                        <ol class="mb-0 mt-1">
                            <li>Que escribas el nombre exacto de la peluquería: <strong>@peluqueria.Nombre</strong></li>
                            <li>Tu contraseña actual</li>
                        </ol>
                    </div>
                    @if (ErrorBorrado == "confirmacion")
                    {
                        <div class="alert alert-danger small py-2"><i class="bi bi-x-circle me-1"></i>El nombre no coincide.</div>
                    }
                    else if (ErrorBorrado == "password")
                    {
                        <div class="alert alert-danger small py-2"><i class="bi bi-x-circle me-1"></i>Contraseña incorrecta.</div>
                    }
                    <input name="confirmacion" class="form-control pc-form-control mb-2" placeholder="Nombre de la peluquería" required />
                    <input type="password" name="password" class="form-control pc-form-control mb-2" placeholder="Tu contraseña actual" required autocomplete="current-password" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Confirmar borrado
                        </button>
                        <button type="button" class="btn btn-light" @onclick="() => confirmandoBorrado = false">Cancelar</button>
                    </div>
                </form>
            }
        </div>
    </div>
}

@code {
    private Peluqueria? peluqueria;
    private FormPerfil form = new();
    private bool cargando = true;
    private bool guardando = false;
    private bool confirmandoBorrado = false;
    private string? mensaje;
    private bool mensajeOk;
    private CancellationTokenSource? mensajeCts;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userId = UserManager.GetUserId(auth.User);
        if (userId is null) { cargando = false; return; }

        var user = await UserManager.FindByIdAsync(userId);
        if (user?.PeluqueriaId is null) { cargando = false; return; }

        peluqueria = await PeluqueriaService.ObtenerPorIdAsync(user.PeluqueriaId.Value);
        if (peluqueria is not null)
        {
            form = new FormPerfil
            {
                Nombre = peluqueria.Nombre,
                Direccion = peluqueria.Direccion,
                GoogleMapsUrl = peluqueria.GoogleMapsUrl ?? string.Empty,
                Telefono = peluqueria.Telefono,
                EmailContacto = peluqueria.EmailContacto,
                Horarios = OrdenSemana.Select(d =>
                {
                    var existente = peluqueria.Horarios.FirstOrDefault(h => h.Dia == d);
                    return new HorarioFormItem
                    {
                        Dia = d,
                        Abierto = existente?.Abierto ?? true,
                        Apertura = (existente?.Apertura ?? new TimeOnly(9, 0)).ToString("HH\\:mm"),
                        Cierre = (existente?.Cierre ?? new TimeOnly(21, 0)).ToString("HH\\:mm")
                    };
                }).ToList()
            };
        }
        cargando = false;
    }

    private async Task Guardar()
    {
        if (peluqueria is null) return;

        // Validar teléfono español
        var telefonoNorm = Validaciones.NormalizarTelefonoEs(form.Telefono);
        if (telefonoNorm is null)
        {
            await MostrarMensaje("Teléfono no válido. Debe ser un número español de 9 dígitos empezando por 6, 7, 8 o 9.", false);
            return;
        }

        // Validar email de contacto
        if (!Validaciones.EsEmailValido(form.EmailContacto))
        {
            await MostrarMensaje("Email de contacto no válido.", false);
            return;
        }

        // Validar y construir horarios
        var horariosFinal = new List<HorarioDia>();
        foreach (var item in form.Horarios)
        {
            if (!item.Abierto)
            {
                horariosFinal.Add(new HorarioDia { Dia = item.Dia, Abierto = false, Apertura = new(9, 0), Cierre = new(21, 0) });
                continue;
            }
            if (!TimeOnly.TryParse(item.Apertura, out var hAp))
            { await MostrarMensaje($"Hora de apertura no válida para {NombreDia(item.Dia)}.", false); return; }
            if (!TimeOnly.TryParse(item.Cierre, out var hCi))
            { await MostrarMensaje($"Hora de cierre no válida para {NombreDia(item.Dia)}.", false); return; }
            if (hCi <= hAp)
            { await MostrarMensaje($"El cierre debe ser posterior a la apertura ({NombreDia(item.Dia)}).", false); return; }
            horariosFinal.Add(new HorarioDia { Dia = item.Dia, Abierto = true, Apertura = hAp, Cierre = hCi });
        }
        if (!horariosFinal.Any(h => h.Abierto))
        {
            await MostrarMensaje("Debes abrir al menos un día.", false);
            return;
        }

        // Spinner ON antes de cualquier operación lenta
        guardando = true;
        StateHasChanged();
        await Task.Yield();

        try
        {
            // Recalcular coordenadas: primero desde URL de Maps (incluyendo cortas), si no geocodificar la dirección.
            var coords = await GeoService.ResolverGoogleMapsUrlAsync(form.GoogleMapsUrl)
                         ?? await GeoService.GeocodificarAsync(form.Direccion);

            var lat = coords?.lat ?? peluqueria.Latitud;
            var lng = coords?.lng ?? peluqueria.Longitud;

            if (lat == 0 && lng == 0)
            {
                await MostrarMensaje("No hemos podido localizar la dirección. Revísala o pega un enlace de Google Maps.", false);
                return;
            }

            await PeluqueriaService.ActualizarPerfilAsync(
                peluqueria.Id, form.Nombre, form.Direccion,
                string.IsNullOrWhiteSpace(form.GoogleMapsUrl) ? null : form.GoogleMapsUrl,
                lat, lng, Validaciones.FormatearTelefono(telefonoNorm), form.EmailContacto);
            await PeluqueriaService.ActualizarHorariosAsync(peluqueria.Id, horariosFinal);
            await MostrarMensaje("Perfil actualizado.", true);
        }
        finally
        {
            guardando = false;
        }
    }

    private static readonly DayOfWeek[] OrdenSemana =
    {
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    };

    private static string NombreDia(DayOfWeek d) => d switch
    {
        DayOfWeek.Monday => "Lunes",
        DayOfWeek.Tuesday => "Martes",
        DayOfWeek.Wednesday => "Miércoles",
        DayOfWeek.Thursday => "Jueves",
        DayOfWeek.Friday => "Viernes",
        DayOfWeek.Saturday => "Sábado",
        DayOfWeek.Sunday => "Domingo",
        _ => "?"
    };

    public class HorarioFormItem
    {
        public DayOfWeek Dia { get; set; }
        public bool Abierto { get; set; } = true;
        public string Apertura { get; set; } = "09:00";
        public string Cierre { get; set; } = "21:00";
    }

    private async Task MostrarMensaje(string texto, bool ok)
    {
        mensajeCts?.Cancel();
        mensajeCts = new CancellationTokenSource();
        var token = mensajeCts.Token;
        mensaje = texto;
        mensajeOk = ok;
        StateHasChanged();
        try { await Task.Delay(3500, token); mensaje = null; StateHasChanged(); }
        catch (TaskCanceledException) { }
    }

    public class FormPerfil
    {
        public string Nombre { get; set; } = string.Empty;
        public string Direccion { get; set; } = string.Empty;
        public string GoogleMapsUrl { get; set; } = string.Empty;
        public string Telefono { get; set; } = string.Empty;
        public string EmailContacto { get; set; } = string.Empty;
        public List<HorarioFormItem> Horarios { get; set; } = new();
    }
}
